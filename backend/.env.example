AGENTTHAT_ENV=development
AGENTTHAT_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://[::1]:3000,http://localhost:3001,http://127.0.0.1:3001,http://[::1]:3001

# Azure OpenAI chat completions configuration.
# Endpoint example: https://your-resource-name.openai.azure.com
# Deployment should be your Azure model deployment name (for example: gpt-4o, gpt-4.1-mini)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_TEMPERATURE=0.2
AZURE_OPENAI_TIMEOUT_SECONDS=90
